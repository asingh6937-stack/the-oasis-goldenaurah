# The Oasis — server-side environment variables.
# Set these in Vercel (Project → Settings → Environment Variables).
# Never put these values in frontend code or commit real keys.

# Wix CRM lead storage.
# Generate the API key at https://manage.wix.com/account/api-keys
WIX_API_KEY=your-wix-api-key

# Site ID of the Wix site that owns Contacts/CRM. Required — the Contacts API is
# a site-level API. Find it in the Wix dashboard URL or under site settings.
WIX_SITE_ID=your-wix-site-id

# Account ID. Optional — only needed if you switch to account-level Wix calls.
# WIX_ACCOUNT_ID=your-wix-account-id
